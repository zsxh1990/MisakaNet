#!/usr/bin/env bash
# scripts/misaka-guard — 跨语言崩溃边车转发入口
#
# 让非 Python 开发者像使用 npx @misaka-net/fatal-guard 一样简单:
#   ./scripts/misaka-guard --to-draft -- <your-command>
#
# 实际调用 python3 -m misakanet.guard，所有参数透传。
set -euo pipefail

# 定位 MisakaNet 仓库根目录（脚本在 scripts/ 下）
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

exec python3 -m misakanet.guard "$@"
