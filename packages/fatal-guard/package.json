  },
  "files": [
    "index.js",
    "register.js",
    "index.d.ts",
    "bin/fatal-guard.js",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ikalus1988/MisakaNet",
    "directory": "packages/fatal-guard"
  },
  "keywords": [
    "fatal",
    "error-handler",
    "uncaught-exception",
    "unhandled-rejection",
    "process-exit",
    "guard",
    "misakanet"
  ],
